generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        BigInt    @id @default(autoincrement())
  email     String    @unique
  name      String?
  createdAt DateTime  @default(now()) @map("created_at")

  projects  Project[]

  @@map("users")
}

model Project {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt    @map("user_id")
  name      String
  domain    String?
  createdAt DateTime  @default(now()) @map("created_at")

  user            User             @relation(fields: [userId], references: [id])
  channelAccounts ChannelAccount[]
  events          Event[]
  dailyStats      DailyStat[]

  @@index([userId])
  @@map("projects")
}

model ChannelAccount {
  id                BigInt    @id @default(autoincrement())
  projectId         BigInt    @map("project_id")
  channelType       String    @map("channel_type")
  accountName       String    @map("account_name")
  externalAccountId String?   @map("external_account_id")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id])
  events  Event[]

  @@index([projectId])
  @@index([channelType])
  @@map("channel_accounts")
}

model Event {
  id               BigInt    @id @default(autoincrement())
  projectId        BigInt    @map("project_id")
  channelAccountId BigInt?   @map("channel_account_id")
  eventType        String    @map("event_type")
  visitorId        String?   @map("visitor_id")
  pageUrl          String    @map("page_url")
  referrer         String?
  occurredAt       DateTime  @default(now()) @map("occurred_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  project        Project         @relation(fields: [projectId], references: [id])
  channelAccount ChannelAccount? @relation(fields: [channelAccountId], references: [id])

  @@index([projectId])
  @@index([channelAccountId])
  @@index([eventType])
  @@index([occurredAt])
  @@map("events")
}

model DailyStat {
  id          BigInt    @id @default(autoincrement())
  projectId   BigInt    @map("project_id")
  statDate    DateTime  @map("stat_date")
  impressions Int       @default(0)
  clicks      Int       @default(0)
  conversions Int       @default(0)
  spend       Decimal   @default(0) @db.Decimal(12, 2)
  revenue     Decimal   @default(0) @db.Decimal(12, 2)
  createdAt   DateTime  @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, statDate])
  @@index([projectId])
  @@map("daily_stats")
}